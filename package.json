{
  "name": "carrot-code",
  "version": "0.1.0",
  "description": "A 2D pixel-art platformer built as a learning project for game programming + Spec-Driven Development practice.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasaimial/carrot-code.git"
  },
  "homepage": "https://github.com/jasaimial/carrot-code#readme",
  "bugs": {
    "url": "https://github.com/jasaimial/carrot-code/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/check-dev-port.mjs",
    "dev": "vite",
    "kill-dev": "node scripts/kill-dev-zombies.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.5",
    "jsdom": "29.1.1",
    "phaser": "4.1.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.6"
  }
}
